{
  "_name": "t11_airtime_sf7_bw125k_cr4",
  "_desc": "Airtime check: SF7 BW=125000 CR=4 (fastest). Msg ~38B should be ~119ms, path ~22B ~78ms.",
  "simulation": {
    "duration_ms": 20000,
    "step_ms": 5,
    "warmup_ms": 5000,
    "hot_start": true,
    "radio": { "sf": 7, "bw": 125000, "cr": 4 }
  },
  "nodes": [
    { "name": "alice", "role": "companion" },
    { "name": "relay1", "role": "repeater" },
    { "name": "bob", "role": "companion" }
  ],
  "topology": {
    "links": [
      { "from": "alice", "to": "relay1", "snr": 10.0, "rssi": -70.0, "bidir": true },
      { "from": "relay1", "to": "bob", "snr": 10.0, "rssi": -70.0, "bidir": true }
    ]
  },
  "commands": [
    { "at_ms": 6000, "node": "alice", "command": "msg bob hello" }
  ],
  "expect": [
    { "type": "cmd_reply_contains", "node": "alice", "command": "msg bob", "value": "msg sent" },
    { "type": "tx_airtime_between", "node": "alice", "min": 70, "max": 170 },
    { "type": "tx_airtime_between", "node": "relay1", "min": 70, "max": 400 }
  ]
}
