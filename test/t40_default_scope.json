{
  "_name": "t40_default_scope",
  "_desc": "Default flood scope: two regions (north/south) with bridge repeater. Cold start with scoped adverts. Intra-region messages deliver, cross-region discovery is blocked by scoping.",
  "simulation": {
    "duration_ms": 210000,
    "step_ms": 5,
    "warmup_ms": 5000
  },
  "nodes": [
    { "name": "alice", "role": "companion" },
    { "name": "RN1", "role": "repeater" },
    { "name": "RN2", "role": "repeater" },
    { "name": "bob", "role": "companion" },
    { "name": "BRIDGE", "role": "repeater" },
    { "name": "RS1", "role": "repeater" },
    { "name": "carol", "role": "companion" },
    { "name": "RS2", "role": "repeater" },
    { "name": "dave", "role": "companion" }
  ],
  "topology": {
    "links": [
      { "from": "alice", "to": "RN1", "snr": 10.0, "rssi": -80.0, "bidir": true },
      { "from": "RN1", "to": "RN2", "snr": 10.0, "rssi": -80.0, "bidir": true },
      { "from": "bob", "to": "RN2", "snr": 10.0, "rssi": -80.0, "bidir": true },
      { "from": "RN2", "to": "BRIDGE", "snr": 10.0, "rssi": -80.0, "bidir": true },
      { "from": "BRIDGE", "to": "RS1", "snr": 10.0, "rssi": -80.0, "bidir": true },
      { "from": "carol", "to": "RS1", "snr": 10.0, "rssi": -80.0, "bidir": true },
      { "from": "RS1", "to": "RS2", "snr": 10.0, "rssi": -80.0, "bidir": true },
      { "from": "dave", "to": "RS2", "snr": 10.0, "rssi": -80.0, "bidir": true }
    ]
  },
  "commands": [
    { "at_ms": 0, "node": "RN1", "command": "region put north" },
    { "at_ms": 0, "node": "RN2", "command": "region put north" },
    { "at_ms": 0, "node": "RS1", "command": "region put south" },
    { "at_ms": 0, "node": "RS2", "command": "region put south" },
    { "at_ms": 0, "node": "BRIDGE", "command": "region put north" },
    { "at_ms": 0, "node": "BRIDGE", "command": "region put south" },

    { "at_ms": 5, "node": "RN1", "command": "region allowf north" },
    { "at_ms": 5, "node": "RN2", "command": "region allowf north" },
    { "at_ms": 5, "node": "RS1", "command": "region allowf south" },
    { "at_ms": 5, "node": "RS2", "command": "region allowf south" },
    { "at_ms": 5, "node": "BRIDGE", "command": "region allowf north" },
    { "at_ms": 5, "node": "BRIDGE", "command": "region allowf south" },

    { "at_ms": 10, "node": "RN1", "command": "region denyf *" },
    { "at_ms": 10, "node": "RN2", "command": "region denyf *" },
    { "at_ms": 10, "node": "RS1", "command": "region denyf *" },
    { "at_ms": 10, "node": "RS2", "command": "region denyf *" },
    { "at_ms": 10, "node": "BRIDGE", "command": "region denyf *" },

    { "at_ms": 15, "node": "RN1", "command": "region default north" },
    { "at_ms": 15, "node": "RN2", "command": "region default north" },
    { "at_ms": 15, "node": "RS1", "command": "region default south" },
    { "at_ms": 15, "node": "RS2", "command": "region default south" },
    { "at_ms": 15, "node": "BRIDGE", "command": "region default north" },

    { "at_ms": 20, "node": "RN1", "command": "region save" },
    { "at_ms": 20, "node": "RN2", "command": "region save" },
    { "at_ms": 20, "node": "RS1", "command": "region save" },
    { "at_ms": 20, "node": "RS2", "command": "region save" },
    { "at_ms": 20, "node": "BRIDGE", "command": "region save" },

    { "at_ms": 25, "node": "alice", "command": "scope north" },
    { "at_ms": 25, "node": "bob", "command": "scope north" },
    { "at_ms": 25, "node": "carol", "command": "scope south" },
    { "at_ms": 25, "node": "dave", "command": "scope south" },

    { "at_ms":  6000, "node": "RN1", "command": "advert" },
    { "at_ms": 10000, "node": "RN2", "command": "advert" },
    { "at_ms": 14000, "node": "BRIDGE", "command": "advert" },
    { "at_ms": 18000, "node": "RS1", "command": "advert" },
    { "at_ms": 22000, "node": "RS2", "command": "advert" },
    { "at_ms": 26000, "node": "alice", "command": "advert" },
    { "at_ms": 30000, "node": "bob", "command": "advert" },
    { "at_ms": 34000, "node": "carol", "command": "advert" },
    { "at_ms": 38000, "node": "dave", "command": "advert" },

    { "at_ms": 44000, "node": "RN1", "command": "advert" },
    { "at_ms": 48000, "node": "RN2", "command": "advert" },
    { "at_ms": 52000, "node": "BRIDGE", "command": "advert" },
    { "at_ms": 56000, "node": "RS1", "command": "advert" },
    { "at_ms": 60000, "node": "RS2", "command": "advert" },
    { "at_ms": 64000, "node": "alice", "command": "advert" },
    { "at_ms": 68000, "node": "bob", "command": "advert" },
    { "at_ms": 72000, "node": "carol", "command": "advert" },
    { "at_ms": 76000, "node": "dave", "command": "advert" },

    { "at_ms":  82000, "node": "RN1", "command": "advert" },
    { "at_ms":  86000, "node": "RN2", "command": "advert" },
    { "at_ms":  90000, "node": "BRIDGE", "command": "advert" },
    { "at_ms":  94000, "node": "RS1", "command": "advert" },
    { "at_ms":  98000, "node": "RS2", "command": "advert" },
    { "at_ms": 102000, "node": "alice", "command": "advert" },
    { "at_ms": 106000, "node": "bob", "command": "advert" },
    { "at_ms": 110000, "node": "carol", "command": "advert" },
    { "at_ms": 114000, "node": "dave", "command": "advert" },

    { "at_ms": 120000, "node": "RN1", "command": "neighbors" },
    { "at_ms": 120000, "node": "RN2", "command": "neighbors" },
    { "at_ms": 120000, "node": "BRIDGE", "command": "neighbors" },
    { "at_ms": 120000, "node": "RS1", "command": "neighbors" },
    { "at_ms": 120000, "node": "RS2", "command": "neighbors" },

    { "at_ms": 130000, "node": "alice", "command": "msg bob hello from north" },
    { "at_ms": 145000, "node": "carol", "command": "msg dave hello from south" },

    { "at_ms": 165000, "node": "alice", "command": "msg carol cross-region test" },

    { "at_ms": 200000, "node": "alice", "command": "stats" },
    { "at_ms": 200000, "node": "bob", "command": "stats" },
    { "at_ms": 200000, "node": "carol", "command": "stats" },
    { "at_ms": 200000, "node": "dave", "command": "stats" }
  ],
  "expect": [
    { "type": "cmd_reply_contains", "node": "RN1", "command": "region default north", "value": "default scope is now north" },
    { "type": "cmd_reply_contains", "node": "RS1", "command": "region default south", "value": "default scope is now south" },
    { "type": "cmd_reply_contains", "node": "BRIDGE", "command": "region save", "value": "OK" },

    { "type": "cmd_reply_not_contains", "node": "RN1", "command": "neighbors", "value": "-none-" },
    { "type": "cmd_reply_not_contains", "node": "RN2", "command": "neighbors", "value": "-none-" },
    { "type": "cmd_reply_not_contains", "node": "BRIDGE", "command": "neighbors", "value": "-none-" },
    { "type": "cmd_reply_not_contains", "node": "RS1", "command": "neighbors", "value": "-none-" },
    { "type": "cmd_reply_not_contains", "node": "RS2", "command": "neighbors", "value": "-none-" },

    { "type": "cmd_reply_contains", "node": "alice", "command": "msg bob", "value": "msg sent to bob" },
    { "type": "cmd_reply_contains", "node": "carol", "command": "msg dave", "value": "msg sent to dave" },

    { "type": "cmd_reply_contains", "node": "bob", "command": "stats", "value": "1 direct" },
    { "type": "cmd_reply_contains", "node": "dave", "command": "stats", "value": "1 direct" },

    { "type": "cmd_reply_contains", "node": "alice", "command": "msg carol", "value": "not found" },

    { "type": "cmd_reply_contains", "node": "carol", "command": "stats", "value": "recv: 0 direct" }
  ]
}
