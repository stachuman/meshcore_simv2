{
  "_name": "t03_cold_start_advert",
  "_desc": "Cold start: explicit adverts with retries, verify multi-hop discovery through relay. Clock stagger causes realistic collisions so multiple rounds are needed.",
  "simulation": {
    "duration_ms": 120000,
    "step_ms": 5,
    "warmup_ms": 5000
  },
  "nodes": [
    { "name": "alice", "role": "companion" },
    { "name": "relay1", "role": "repeater" },
    { "name": "relay2", "role": "repeater" },
    { "name": "bob", "role": "companion" }
  ],
  "topology": {
    "links": [
      { "from": "alice", "to": "relay1", "snr": 8.0, "rssi": -80.0, "bidir": true },
      { "from": "relay1", "to": "relay2", "snr": 5.0, "rssi": -90.0, "bidir": true },
      { "from": "relay2", "to": "bob", "snr": 8.0, "rssi": -80.0, "bidir": true }
    ]
  },
  "commands": [
    { "at_ms": 6000, "node": "alice", "command": "advert" },
    { "at_ms": 15000, "node": "relay1", "command": "advert" },
    { "at_ms": 15000, "node": "relay2", "command": "advert" },
    { "at_ms": 25000, "node": "bob", "command": "advert" },
    { "at_ms": 35000, "node": "alice", "command": "advert" },
    { "at_ms": 45000, "node": "relay1", "command": "advert" },
    { "at_ms": 45000, "node": "relay2", "command": "advert" },
    { "at_ms": 55000, "node": "bob", "command": "advert" },
    { "at_ms": 65000, "node": "alice", "command": "advert" },
    { "at_ms": 75000, "node": "relay1", "command": "advert" },
    { "at_ms": 75000, "node": "relay2", "command": "advert" },
    { "at_ms": 85000, "node": "bob", "command": "advert" },
    { "at_ms": 105000, "node": "alice", "command": "neighbors" },
    { "at_ms": 105000, "node": "bob", "command": "neighbors" }
  ],
  "expect": [
    { "type": "cmd_reply_contains", "node": "alice", "command": "neighbors", "value": "bob" },
    { "type": "cmd_reply_contains", "node": "alice", "command": "neighbors", "value": "relay1" },
    { "type": "cmd_reply_contains", "node": "bob", "command": "neighbors", "value": "alice" },
    { "type": "cmd_reply_contains", "node": "bob", "command": "neighbors", "value": "relay2" }
  ]
}
