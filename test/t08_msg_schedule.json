{
  "_name": "t08_msg_schedule",
  "_desc": "Verify message_schedule expands and periodic messages fire",
  "simulation": {
    "duration_ms": 30000,
    "step_ms": 5,
    "warmup_ms": 5000,
    "hot_start": true
  },
  "nodes": [
    { "name": "alice", "role": "companion" },
    { "name": "relay1", "role": "repeater" },
    { "name": "bob", "role": "companion" }
  ],
  "topology": {
    "links": [
      { "from": "alice", "to": "relay1", "snr": 8.0, "rssi": -80.0, "bidir": true },
      { "from": "relay1", "to": "bob", "snr": 8.0, "rssi": -80.0, "bidir": true }
    ]
  },
  "message_schedule": [
    {
      "from": "alice",
      "to": "bob",
      "start_ms": 7000,
      "interval_ms": 5000,
      "count": 3,
      "message": "periodic #{n}"
    }
  ],
  "expect": [
    { "type": "cmd_reply_contains", "node": "alice", "command": "msg bob", "value": "msg sent to bob" },
    { "type": "event_count_min", "value": "tx", "count": 3 },
    { "type": "event_count_min", "value": "rx", "count": 3 }
  ]
}
