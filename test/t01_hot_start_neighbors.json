{
  "_name": "t01_hot_start_neighbors",
  "_desc": "Hot start: companions discover each other through relay without explicit adverts",
  "simulation": {
    "duration_ms": 10000,
    "step_ms": 5,
    "warmup_ms": 5000,
    "hot_start": true
  },
  "nodes": [
    { "name": "alice", "role": "companion" },
    { "name": "relay1", "role": "repeater" },
    { "name": "bob", "role": "companion" }
  ],
  "topology": {
    "links": [
      { "from": "alice", "to": "relay1", "snr": 8.0, "rssi": -80.0, "bidir": true },
      { "from": "relay1", "to": "bob", "snr": 8.0, "rssi": -80.0, "bidir": true }
    ]
  },
  "commands": [
    { "at_ms": 6000, "node": "alice", "command": "neighbors" },
    { "at_ms": 6000, "node": "bob", "command": "neighbors" }
  ],
  "expect": [
    { "type": "cmd_reply_contains", "node": "alice", "command": "neighbors", "value": "bob" },
    { "type": "cmd_reply_contains", "node": "alice", "command": "neighbors", "value": "relay1" },
    { "type": "cmd_reply_contains", "node": "bob", "command": "neighbors", "value": "alice" },
    { "type": "cmd_reply_contains", "node": "bob", "command": "neighbors", "value": "relay1" }
  ]
}
