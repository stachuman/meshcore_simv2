{
  "_name": "t44_phase2_query_happy",
  "_desc": "Phase 2: cold-start DM emits a PATH_REQ to alice's neighborhood; R1 (with bob in its hot-started RouteCache) replies with a PATH_OFFER; the deferred packet ships via sendDirect once the offer window resolves. A second msga (sent after the path is installed) is tracked as a direct-ack send and the ack returns via path — visible as path_acks: 1/1. Stronger than asserting PATH_REQ traffic only: this proves Phase 2 actually resolved to direct delivery, not just that PATH_REQ appeared on the wire.",
  "_requires_plugins": ["fw_routing"],
  "simulation": {
    "firmware": { "default": "fw_routing" },
    "duration_ms": 60000,
    "step_ms": 5,
    "warmup_ms": 5000,
    "hot_start": true
  },
  "nodes": [
    { "name": "alice", "role": "companion" },
    { "name": "R1",    "role": "repeater"  },
    { "name": "R2",    "role": "repeater"  },
    { "name": "bob",   "role": "companion" }
  ],
  "topology": {
    "links": [
      { "from": "alice", "to": "R1",  "snr": 8.0, "rssi": -80.0, "bidir": true },
      { "from": "R1",    "to": "R2",  "snr": 6.0, "rssi": -85.0, "bidir": true },
      { "from": "R2",    "to": "bob", "snr": 8.0, "rssi": -80.0, "bidir": true }
    ]
  },
  "commands": [
    { "at_ms": 30000, "node": "alice", "command": "msga bob hello-phase2" },
    { "at_ms": 40000, "node": "alice", "command": "msga bob second-direct" },
    { "at_ms": 50000, "node": "alice", "command": "stats" },
    { "at_ms": 50500, "node": "bob",   "command": "stats" }
  ],
  "expect": [
    { "type": "cmd_reply_contains", "node": "alice", "command": "msga bob hello-phase2",  "value": "flood, ack tracked" },
    { "type": "cmd_reply_contains", "node": "alice", "command": "msga bob second-direct", "value": "direct, ack tracked" },
    { "type": "cmd_reply_contains", "node": "alice", "command": "stats",                  "value": "flood_acks: 1/1" },
    { "type": "cmd_reply_contains", "node": "alice", "command": "stats",                  "value": "path_acks: 1/1" },
    { "type": "cmd_reply_contains", "node": "bob",   "command": "stats",                  "value": "alice:2" },
    { "type": "event_count", "event_type": "tx", "node": "alice", "min": 3 },
    { "type": "event_count", "event_type": "tx", "node": "R1",    "min": 2 }
  ]
}
