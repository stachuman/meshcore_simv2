{
  "_name": "t31_direct_path_overhear",
  "_desc": "Explores flood path selection and direct-route overhear behavior. Topology: alice-B-C-D-E-frank chain (strong links, SNR 10) plus a weaker B-E shortcut (SNR 3, bidirectional). Question: which path does the flood learn, and how do direct messages behave when intermediate repeaters can overhear transmissions not addressed to them?",
  "simulation": {
    "duration_ms": 180000,
    "step_ms": 4,
    "warmup_ms": 5000,
    "hot_start": true,
    "seed": 42
  },
  "nodes": [
    {"name": "alice", "role": "companion"},
    {"name": "B", "role": "repeater"},
    {"name": "C", "role": "repeater"},
    {"name": "D", "role": "repeater"},
    {"name": "E", "role": "repeater"},
    {"name": "frank", "role": "companion"}
  ],
  "topology": {
    "links": [
      {"from": "alice", "to": "B", "snr": 10, "rssi": -70},
      {"from": "B", "to": "C", "snr": 10, "rssi": -70},
      {"from": "C", "to": "D", "snr": 10, "rssi": -70},
      {"from": "D", "to": "E", "snr": 10, "rssi": -70},
      {"from": "E", "to": "frank", "snr": 10, "rssi": -70},
      {"from": "B", "to": "E", "snr": 3, "rssi": -90}
    ]
  },
  "commands": [
    {"at_ms": 5000, "node": "@repeaters", "command": "set path.hash.mode 1"},
    {"at_ms": 5005, "node": "@repeaters", "command": "get rxdelay"},
    {"at_ms": 6000, "node": "alice", "command": "msg frank flood_msg"},
    {"at_ms": 60000, "node": "alice", "command": "msg frank direct_msg1"},
    {"at_ms": 110000, "node": "alice", "command": "msg frank direct_msg2"}
  ],
  "expect": [
    {"type": "cmd_reply_contains", "node": "alice", "command": "msg frank flood_msg", "value": "sent"},
    {"type": "cmd_reply_contains", "node": "alice", "command": "msg frank direct_msg1", "value": "sent"},
    {"type": "cmd_reply_contains", "node": "alice", "command": "msg frank direct_msg2", "value": "sent"}
  ]
}
