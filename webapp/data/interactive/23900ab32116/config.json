{
  "_name": "t42_scope_mixed_bridge",
  "_desc": "Mixed firmware scoped network: same topology as t40 (north/south regions with bridge), but BRIDGE runs fw_default (no scope support). Tests whether a non-scoped bridge leaks packets across regions that scoped repeaters would normally block.",
  "_requires_plugins": [
    "fw_scope"
  ],
  "simulation": {
    "firmware": {
      "default": "fw_scope"
    },
    "duration_ms": 210000,
    "step_ms": 5,
    "warmup_ms": 5000
  },
  "nodes": [
    {
      "name": "alice-N",
      "role": "companion"
    },
    {
      "name": "RN1",
      "role": "repeater"
    },
    {
      "name": "RN2",
      "role": "repeater"
    },
    {
      "name": "bob-N",
      "role": "companion"
    },
    {
      "name": "BRIDGE",
      "role": "repeater",
      "firmware": "fw_default"
    },
    {
      "name": "RS1",
      "role": "repeater"
    },
    {
      "name": "carol-S",
      "role": "companion"
    },
    {
      "name": "RS2",
      "role": "repeater"
    },
    {
      "name": "dave-S",
      "role": "companion"
    }
  ],
  "topology": {
    "links": [
      {
        "from": "alice-N",
        "to": "RN1",
        "snr": 10,
        "rssi": -80,
        "bidir": true
      },
      {
        "from": "RN1",
        "to": "RN2",
        "snr": 10,
        "rssi": -80,
        "bidir": true
      },
      {
        "from": "bob-N",
        "to": "RN2",
        "snr": 10,
        "rssi": -80,
        "bidir": true
      },
      {
        "from": "RN2",
        "to": "BRIDGE",
        "snr": 10,
        "rssi": -80,
        "bidir": true
      },
      {
        "from": "BRIDGE",
        "to": "RS1",
        "snr": 10,
        "rssi": -80,
        "bidir": true
      },
      {
        "from": "carol-S",
        "to": "RS1",
        "snr": 10,
        "rssi": -80,
        "bidir": true
      },
      {
        "from": "RS1",
        "to": "RS2",
        "snr": 10,
        "rssi": -80,
        "bidir": true
      },
      {
        "from": "dave-S",
        "to": "RS2",
        "snr": 10,
        "rssi": -80,
        "bidir": true
      }
    ]
  },
  "commands": [
    {
      "at_ms": 0,
      "node": "RN1",
      "command": "region put north"
    },
    {
      "at_ms": 0,
      "node": "RN2",
      "command": "region put north"
    },
    {
      "at_ms": 0,
      "node": "RS1",
      "command": "region put south"
    },
    {
      "at_ms": 0,
      "node": "RS2",
      "command": "region put south"
    },
    {
      "at_ms": 5,
      "node": "RN1",
      "command": "region allowf north"
    },
    {
      "at_ms": 5,
      "node": "RN2",
      "command": "region allowf north"
    },
    {
